# Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/skill_system"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI API 供应方选择
# 可选值: kimi, evolink, openai, local
AI_PROVIDER="evolink"

# OpenAI API
OPENAI_API_KEY=""

# Kimi (月之暗面) API
KIMI_API_KEY=""

# Evolink AI API
EVOLINK_API_KEY=""
